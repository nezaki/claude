{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(find:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(git push:*)"
    ],
    "ask": []
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 &",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 &",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "nohup afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 &",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 &",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 &",
            "async": true
          }
        ]
      }
    ]
  }
}
